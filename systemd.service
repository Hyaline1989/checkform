[Unit]
Description=Call Evaluation System
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/call-evaluation-system
Environment="PATH=/var/www/call-evaluation-system/venv/bin"
ExecStart=/var/www/call-evaluation-system/venv/bin/gunicorn -c /var/www/call-evaluation-system/gunicorn_config.py wsgi:app
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target